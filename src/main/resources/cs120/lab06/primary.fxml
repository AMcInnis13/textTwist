<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="cs120.lab06.PrimaryController"
    styleClass="root">

    <left>
        <VBox prefWidth="180" styleClass="found-words-panel">
            <BorderPane.margin>
                <Insets top="8" right="0" bottom="8" left="8" />
            </BorderPane.margin>
            <children>
                <Label text="FOUND WORDS" styleClass="section-header">
                    <VBox.margin>
                        <Insets top="8" left="8" />
                    </VBox.margin>
                </Label>
                <ListView fx:id="foundWordsList" prefWidth="180" styleClass="found-words-list" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox styleClass="center-vbox" spacing="12">
            <BorderPane.margin>
                <Insets top="8" right="8" bottom="8" left="4" />
            </BorderPane.margin>
            <padding>
                <Insets top="10" right="14" bottom="10" left="14" />
            </padding>
            <children>

                <!-- Score / Level / Time row -->
                <HBox styleClass="info-hbox" spacing="20" alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="scoreLabel" text="Score: 0" styleClass="info-label" />
                        <Label fx:id="levelLabel" text="Level: 1" styleClass="info-label" />
                        <Label fx:id="timeLabel"  text="2:00"    styleClass="info-label time-label" />
                    </children>
                </HBox>

                <!-- Letter buttons area — populated dynamically by Phase 3 -->
                <FlowPane fx:id="letterButtonArea" styleClass="letter-area"
                          hgap="8" vgap="8"
                          prefWrapLength="400"
                          alignment="CENTER"
                          minHeight="70" />

                <!-- Guess display — Labels added/removed dynamically by Phase 3 -->
                <HBox fx:id="guessDisplay" styleClass="guess-display"
                      spacing="4"
                      alignment="CENTER"
                      minHeight="50"
                      minWidth="200" />

                <!-- Control buttons row -->
                <HBox styleClass="control-hbox" spacing="8" alignment="CENTER">
                    <children>
                        <Button fx:id="twistBtn"    text="Twist"     styleClass="control-btn" />
                        <Button fx:id="enterBtn"    text="Enter"     styleClass="control-btn" />
                        <Button fx:id="lastWordBtn" text="Last Word" styleClass="control-btn" disable="true" />
                        <Button fx:id="clearBtn"    text="Clear"     styleClass="control-btn" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>
